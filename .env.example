# Copy this to .env and fill in your actual credentials for local testing
# Mailo credentials (used for both IMAP reading and SMTP sending)
IMAP_USER=your-full-mailo-address@netc.fr
IMAP_PASS=your_mailo_password
FORWARD_TO=your-gmail-address@gmail.com
CHECK_INTERVAL=300

# Optional: Logging configuration
LOG_LEVEL=INFO
LOG_FILE=/app/logs/forwarder.log
