# Copy this to .env and fill in your actual credentials for local testing
# Mailo credentials (used for both IMAP reading and SMTP sending)
IMAP_USER=your-full-mailo-address@netc.fr
IMAP_PASS=your_mailo_password
FORWARD_TO=your-gmail-address@gmail.com
CHECK_INTERVAL=300

# Email backend: 'smtp' (Mailo) or 'resend' (recommended, more reliable)
EMAIL_BACKEND=smtp

# SMTP configuration (only used if EMAIL_BACKEND=smtp)
# 587 for STARTTLS, 465 for SSL
SMTP_PORT=465
SMTP_TIMEOUT=60
SMTP_TLS_MODE=auto

# Resend configuration (only used if EMAIL_BACKEND=resend)
# Get your API key from https://resend.com
RESEND_API_KEY=
RESEND_FROM=your-full-mailo-address@netc.fr

# Optional: Delete original message after forwarding (true/false)
DELETE_AFTER_FORWARD=false

# Optional: Logging configuration
LOG_LEVEL=INFO
LOG_FILE=/app/logs/forwarder.log
